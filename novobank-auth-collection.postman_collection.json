{
  "info": {
    "name": "NovoBanco — Auth Service",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "novobank-auth-v1"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8081" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "customerId", "value": "a1b2c3d4-e5f6-7890-abcd-ef1234567890" }
  ],
  "item": [
    {
      "name": "Happy Path",
      "item": [
        {
          "name": "Registrar usuario",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@novobanco.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Juan Pérez\",\n  \"customerId\": \"{{customerId}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Has userId', () => pm.expect(pm.response.json().userId).to.not.be.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login exitoso",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@novobanco.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const response = pm.response.json();",
                  "pm.environment.set('accessToken', response.accessToken);",
                  "pm.environment.set('refreshToken', response.refreshToken);",
                  "pm.test('Has tokens', () => {",
                  "  pm.expect(response.accessToken).to.not.be.empty;",
                  "  pm.expect(response.refreshToken).to.not.be.empty;",
                  "  pm.expect(response.tokenType).to.equal('Bearer');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Obtener usuario actual (/me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Has user data', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.email).to.not.be.empty;",
                  "  pm.expect(body.role).to.equal('CUSTOMER');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const body = pm.response.json();",
                  "pm.environment.set('accessToken', body.accessToken);",
                  "pm.test('Has new access token', () => pm.expect(body.accessToken).to.not.be.empty);"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
        {
          "name": "Login — password incorrecto (401 genérico)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@novobanco.com\",\n  \"password\": \"passwordincorrecto\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message is generic', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.detail).to.equal('Email o contraseña incorrectos');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Login — email inexistente (401 genérico)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noexiste@novobanco.com\",\n  \"password\": \"Password123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));",
                  "pm.test('Error message is generic', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.detail).to.equal('Email o contraseña incorrectos');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Registro — email duplicado (409)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@novobanco.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Otro\",\n  \"customerId\": \"b2c3d4e5-f6a7-8901-bcde-f12345678901\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 409', () => pm.response.to.have.status(409));"
                ]
              }
            }
          ]
        },
        {
          "name": "Token inválido en /me (401)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer token.invalido.aqui" }],
            "url": "{{baseUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Sin token en /me (401)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh token revocado (401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        },
        {
          "name": "Password muy corto en registro (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@novobanco.com\",\n  \"password\": \"123\",\n  \"fullName\": \"Test\",\n  \"customerId\": \"c3d4e5f6-a7b8-9012-cdef-123456789012\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Request sin campo requerido (400)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"juan.perez@novobanco.com\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Flujo Completo E2E",
      "item": [
        {
          "name": "1 — Registrar usuario E2E",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2e.test@novobanco.com\",\n  \"password\": \"E2eTest123!\",\n  \"fullName\": \"Usuario E2E\",\n  \"customerId\": \"d4e5f6a7-b8c9-0123-defa-234567890123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 201', () => pm.response.to.have.status(201));"] }
            }
          ]
        },
        {
          "name": "2 — Login (guarda tokens automáticamente)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"e2e.test@novobanco.com\",\n  \"password\": \"E2eTest123!\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "const response = pm.response.json();",
                  "pm.environment.set('accessToken', response.accessToken);",
                  "pm.environment.set('refreshToken', response.refreshToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "3 — Verificar /me con token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "4 — Refresh token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.environment.set('accessToken', pm.response.json().accessToken);"
                ]
              }
            }
          ]
        },
        {
          "name": "5 — Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/api/v1/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 204', () => pm.response.to.have.status(204));"] }
            }
          ]
        },
        {
          "name": "6 — Verificar refresh revocado (espera 401)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('Status 401 after logout', () => pm.response.to.have.status(401));"] }
            }
          ]
        }
      ]
    }
  ]
}
