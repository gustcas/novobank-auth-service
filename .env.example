# JWT — generate a secure random value of at least 256 bits
JWT_SECRET=cambia_esto_por_minimo_256_bits_en_produccion
JWT_EXPIRATION_MS=900000
JWT_REFRESH_EXPIRATION_MS=604800000

# Auth-service database (novobank_auth)
DB_URL=jdbc:postgresql://postgres-auth:5432/novobank_auth
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Server
SERVER_PORT=8081

# CORS — comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://tu-frontend.netlify.app

# pgAdmin (optional)
PGADMIN_EMAIL=admin@novobanco.com
PGADMIN_PASSWORD=admin
